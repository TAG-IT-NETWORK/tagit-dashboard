# WalletConnect Project ID - Get one at https://cloud.walletconnect.com/
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_project_id_here

# OP Sepolia RPC - Get one at https://www.alchemy.com/
NEXT_PUBLIC_OP_SEPOLIA_RPC=https://opt-sepolia.g.alchemy.com/v2/your_api_key_here

# Arbitrum Sepolia RPC
NEXT_PUBLIC_ARBITRUM_SEPOLIA_RPC=https://arb-sepolia.g.alchemy.com/v2/your_api_key_here

# Primary chain for the hackathon demo (arbitrum_sepolia | op_sepolia)
NEXT_PUBLIC_PRIMARY_CHAIN=arbitrum_sepolia

# Enable dual-chain support (true | false)
NEXT_PUBLIC_MULTI_CHAIN_ENABLED=true

# Subgraph URL (optional — when set, EventFeed uses subgraph instead of RPC polling)
# NEXT_PUBLIC_SUBGRAPH_URL=https://api.goldsky.com/api/public/project_XXX/subgraphs/tagit-core/v1/gn
